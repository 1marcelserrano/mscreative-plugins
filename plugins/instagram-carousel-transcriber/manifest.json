{
  "manifest_version": 3,
  "name": "Transcritor de Carrossel do Instagram",
  "description": "Lê todos os slides de um carrossel do Instagram via OCR local e gera um único .md. Tudo no navegador.",
  "version": "0.2.0",
  "permissions": ["activeTab", "downloads", "storage"],
  "options_page": "src/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["src/content.js"]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Transcrever carrossel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["vendor/*"],
      "matches": ["https://www.instagram.com/*"]
    }
  ]
}
